<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_background"
    android:orientation="vertical"
    android:padding="8dp"
    app:layout_behavior="@string/bottom_sheet_behavior"
    app:behavior_hideable="true">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:background="#3A3A5E"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="New Transaction"
        android:textColor="@color/colorTextPrimary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <Button
            android:id="@+id/bottom_sheet_income_btn"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/button_income"
            android:drawableStart="@drawable/ic_arrow_up"
            android:drawablePadding="8dp"
            android:text="Income"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:textColor="@color/colorIncome"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/bottom_sheet_expense_btn"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/button_expense"
            android:drawableStart="@drawable/ic_arrow_down"
            android:drawablePadding="8dp"
            android:text="Expense"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:textColor="@color/colorExpense"
            android:textStyle="bold"/>

    </LinearLayout>

</LinearLayout>