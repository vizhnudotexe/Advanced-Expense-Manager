<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/colorBackground"
    tools:context=".activities.AddExpenseActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Amount Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/colorCard"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_money"
                    android:tint="@color/colorPrimary"
                    android:layout_marginEnd="12dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/amountTextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Amount">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/amountTextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="28sp"
                        android:textStyle="bold"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Date Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/colorCard"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:id="@+id/dateLinerLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_calendar"
                    android:tint="@color/colorPrimary"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Date"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="15sp"/>

                <TextView
                    android:id="@+id/dateTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01-01-2024"
                    android:textSize="16sp"
                    android:textColor="@color/colorPrimary"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Wallet Selector Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/walletCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/colorCard"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_wallet"
                        android:tint="@color/colorPrimary"
                        android:layout_marginEnd="10dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Wallet"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/walletChipsLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/chipWalletCash"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/chip_background">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_money"
                            android:tint="@color/colorTextPrimary"
                            android:layout_marginEnd="6dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cash"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/chipWalletUpi"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/chip_background">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_bank"
                            android:tint="@color/colorTextPrimary"
                            android:layout_marginEnd="6dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="UPI"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/chipWalletCard"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/chip_background">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_card"
                            android:tint="@color/colorTextPrimary"
                            android:layout_marginEnd="6dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Card"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="13sp"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Category Chips Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/categoryCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/colorCard"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_label"
                        android:tint="@color/colorPrimary"
                        android:layout_marginEnd="10dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Category"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="13sp"/>
                </LinearLayout>

                <HorizontalScrollView
                    android:id="@+id/categoryScrollView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">
                    <LinearLayout
                        android:id="@+id/categoryChipsLayout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Food chip -->
                        <LinearLayout android:id="@+id/chipFood"
                            android:layout_width="wrap_content" android:layout_height="44dp"
                            android:layout_marginEnd="8dp" android:paddingStart="14dp" android:paddingEnd="14dp"
                            android:orientation="horizontal" android:gravity="center"
                            android:background="@drawable/chip_background">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:src="@drawable/ic_food" android:tint="@color/colorTextPrimary"
                                android:layout_marginEnd="6dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Food" android:textSize="13sp" android:textColor="@color/colorTextPrimary"/>
                        </LinearLayout>

                        <!-- Travel chip -->
                        <LinearLayout android:id="@+id/chipTravel"
                            android:layout_width="wrap_content" android:layout_height="44dp"
                            android:layout_marginEnd="8dp" android:paddingStart="14dp" android:paddingEnd="14dp"
                            android:orientation="horizontal" android:gravity="center"
                            android:background="@drawable/chip_background">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:src="@drawable/ic_travel" android:tint="@color/colorTextPrimary"
                                android:layout_marginEnd="6dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Travel" android:textSize="13sp" android:textColor="@color/colorTextPrimary"/>
                        </LinearLayout>

                        <!-- Clothes chip -->
                        <LinearLayout android:id="@+id/chipClothes"
                            android:layout_width="wrap_content" android:layout_height="44dp"
                            android:layout_marginEnd="8dp" android:paddingStart="14dp" android:paddingEnd="14dp"
                            android:orientation="horizontal" android:gravity="center"
                            android:background="@drawable/chip_background">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:src="@drawable/ic_clothes" android:tint="@color/colorTextPrimary"
                                android:layout_marginEnd="6dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Clothes" android:textSize="13sp" android:textColor="@color/colorTextPrimary"/>
                        </LinearLayout>

                        <!-- Movies chip -->
                        <LinearLayout android:id="@+id/chipMovies"
                            android:layout_width="wrap_content" android:layout_height="44dp"
                            android:layout_marginEnd="8dp" android:paddingStart="14dp" android:paddingEnd="14dp"
                            android:orientation="horizontal" android:gravity="center"
                            android:background="@drawable/chip_background">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:src="@drawable/ic_movies" android:tint="@color/colorTextPrimary"
                                android:layout_marginEnd="6dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Movies" android:textSize="13sp" android:textColor="@color/colorTextPrimary"/>
                        </LinearLayout>

                        <!-- Health chip -->
                        <LinearLayout android:id="@+id/chipHealth"
                            android:layout_width="wrap_content" android:layout_height="44dp"
                            android:layout_marginEnd="8dp" android:paddingStart="14dp" android:paddingEnd="14dp"
                            android:orientation="horizontal" android:gravity="center"
                            android:background="@drawable/chip_background">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:src="@drawable/ic_health" android:tint="@color/colorTextPrimary"
                                android:layout_marginEnd="6dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Health" android:textSize="13sp" android:textColor="@color/colorTextPrimary"/>
                        </LinearLayout>

                        <!-- Grocery chip -->
                        <LinearLayout android:id="@+id/chipGrocery"
                            android:layout_width="wrap_content" android:layout_height="44dp"
                            android:layout_marginEnd="8dp" android:paddingStart="14dp" android:paddingEnd="14dp"
                            android:orientation="horizontal" android:gravity="center"
                            android:background="@drawable/chip_background">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:src="@drawable/ic_grocery" android:tint="@color/colorTextPrimary"
                                android:layout_marginEnd="6dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Grocery" android:textSize="13sp" android:textColor="@color/colorTextPrimary"/>
                        </LinearLayout>

                        <!-- Add Custom chip -->
                        <LinearLayout android:id="@+id/chipAddCustom"
                            android:layout_width="wrap_content" android:layout_height="44dp"
                            android:layout_marginEnd="8dp" android:paddingStart="14dp" android:paddingEnd="14dp"
                            android:orientation="horizontal" android:gravity="center"
                            android:background="@drawable/chip_background">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:src="@drawable/ic_add" android:tint="@color/colorAccent"
                                android:layout_marginEnd="6dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Add" android:textSize="13sp" android:textColor="@color/colorAccent"/>
                        </LinearLayout>

                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Recurring Toggle Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/recurringCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/colorCard"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_recurring"
                        android:tint="@color/colorPrimary"
                        android:layout_marginEnd="10dp"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Recurring Transaction"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="15sp"/>
                    <Switch
                        android:id="@+id/recurringSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Recurrence type selector (hidden by default) -->
                <LinearLayout
                    android:id="@+id/recurrenceTypeLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:id="@+id/chipDaily"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:gravity="center"
                        android:text="Daily"
                        android:textSize="13sp"
                        android:textColor="@color/colorTextPrimary"
                        android:background="@drawable/chip_background"/>

                    <TextView
                        android:id="@+id/chipWeekly"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:gravity="center"
                        android:text="Weekly"
                        android:textSize="13sp"
                        android:textColor="@color/colorTextPrimary"
                        android:background="@drawable/chip_background"/>

                    <TextView
                        android:id="@+id/chipMonthly"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Monthly"
                        android:textSize="13sp"
                        android:textColor="@color/colorTextPrimary"
                        android:background="@drawable/chip_background"/>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Description Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/colorCard"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_note"
                    android:tint="@color/colorPrimary"
                    android:layout_marginEnd="12dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/descriptionTextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Note (optional)">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/descriptionTextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName|textCapSentences"
                        android:textColor="@color/colorTextPrimary"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
